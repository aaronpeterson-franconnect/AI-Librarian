{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "ConnectionStrings": {
    "Postgres": ""
  },

  "Search": {
    "HybridVectorWeight": 0.6,
    "DefaultLimit": 15,
    "MaxLimit": 50,
    "ExpectedEmbeddingDimensions": 1536,
    "EmbeddingDeployment": ""
  },

  "PersonaRetrieval": {
    "_comment": "ADR 0015 persona-aware retrieval. When a personaId is set on the session, the decorator over-fetches OverFetchFactor x requested-limit candidates (capped by MaxOverFetchLimit) and reranks via the persona's retrieval_profile JSONB before truncating to the requested limit. RLS runs before this; persona only reorders, never widens.",
    "OverFetchFactor": 3,
    "MaxOverFetchLimit": 150
  },

  "IngestQueue": {
    "ConnectionString": "",
    "QueueName": "ingest-jobs"
  },

  "BlobStorage": {
    "ConnectionString": "",
    "ContainerName": "sources"
  },

  "Portal": {
    "CorsOrigins": "http://localhost:5215",
    "DefaultDepartmentId": "",
    "DefaultClassification": "Internal",
    "DevelopmentRlsOverrideEnabled": false
  },

  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "",
    "ClientId": "",
    "Audience": ""
  },

  "ApplicationInsights": {
    "ConnectionString": ""
  },

  "Auditing": {
    "WriterMode": "Postgres",
    "DegradedModeAllowed": false,
    "RefuseToStartOnProbeFailure": true,
    "CircuitBreaker": {
      "FailureThreshold": 5,
      "BreakDuration": "00:00:30"
    }
  },

  "EntraSync": {
    "_comment": "Reconciles Entra group membership into user_authorizations. Enabled=false keeps the hosted service idle; setting Enabled=true requires TenantId/ClientId/ClientSecret plus at least one GroupMappings row. See deploy/runbooks/entra-app-registrations.md for setup.",
    "Enabled": false,
    "TenantId": "",
    "ClientId": "",
    "ClientSecret": "",
    "Interval": "00:15:00",
    "GraphRequestTimeout": "00:00:30",
    "GroupMappings": []
  },

  "WikiMaintenance": {
    "_comment": "On-demand wiki maintenance via POST /api/admin/wiki/maintain + periodic Cascade-Regeneration Worker. Manual endpoint always works; the cascade worker is off by default. See deploy/runbooks/wiki-maintenance.md.",
    "CascadeRegenerationEnabled": false,
    "Interval": "01:00:00",
    "RetrievalLimit": 20,
    "HybridVectorWeight": 0.6,
    "MaxFacetsPerCascadeTick": 10
  },

  "WikiMaintainer": {
    "_comment": "Wiki Maintainer per-call defaults. EmbeddingScorer:EmbeddingDeployment is the opt-in for embedding-similarity confidence; leave empty to keep the Pass-2 placeholder (0.85).",
    "Model": "gpt-4o-mini",
    "MaxTokens": 2048,
    "Temperature": 0.2,
    "DefaultCitationConfidence": 0.85,
    "DefaultCitationSpanLength": 200,
    "EmbeddingScorer": {
      "EmbeddingDeployment": ""
    }
  },

  "WikiCandidateDiscovery": {
    "_comment": "Cluster-based candidate discovery via POST /api/admin/wiki/discover-candidates. EmbeddingDeployment defaults to Search:EmbeddingDeployment when blank.",
    "EmbeddingDeployment": "",
    "ChatDeployment": "gpt-4o-mini",
    "RepresentativesPerCluster": 3,
    "MaxCharsPerChunk": 2048,
    "MaxNamingTokens": 200,
    "NamingTemperature": 0.2
  },

  "LlmGateway": {
    "DefaultChatProvider": "azure-openai",
    "DefaultEmbeddingProvider": "azure-openai",
    "DefaultRerankProvider": null,
    "Providers": {
      "azure-openai": {
        "DisplayName": "Azure OpenAI Service",
        "Enabled": false,
        "Tier": "Enterprise",
        "DataHandling": {
          "NoTraining": true,
          "RetentionDays": 30,
          "NoHumanReview": true,
          "TenantBound": true,
          "ContractReference": "Azure OpenAI Service \u2014 Enterprise terms (see docs/llm-providers.md)"
        },
        "Endpoint": "",
        "ChatDeployment": "",
        "EmbeddingDeployment": "",
        "ApiKey": "",
        "Models": [ "gpt-4o", "gpt-4o-mini", "text-embedding-3-large" ]
      },
      "anthropic": {
        "DisplayName": "Anthropic API",
        "Enabled": false,
        "Tier": "Enterprise",
        "DataHandling": {
          "NoTraining": true,
          "RetentionDays": 30,
          "NoHumanReview": true,
          "TenantBound": false,
          "ContractReference": "Anthropic Enterprise Agreement (see docs/llm-providers.md)"
        },
        "Endpoint": "https://api.anthropic.com",
        "Models": [ "claude-3-5-sonnet-latest", "claude-3-5-haiku-latest" ]
      },
      "ollama": {
        "DisplayName": "Ollama (self-hosted)",
        "Enabled": false,
        "Tier": "SelfHosted",
        "DataHandling": {
          "NoTraining": true,
          "RetentionDays": 0,
          "NoHumanReview": true,
          "TenantBound": true,
          "ContractReference": "Self-hosted; no provider data-handling applies"
        },
        "Endpoint": "http://localhost:11434",
        "Models": []
      }
    }
  }
}
