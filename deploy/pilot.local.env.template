# Copy to a local, uncommitted file (for example deploy/pilot.local.env) and
# replace placeholders with values from your pilot Azure resource group.
# PowerShell import:
#   Get-Content deploy/pilot.local.env | Where-Object { $_ -and -not $_.StartsWith("#") } | ForEach-Object { $n,$v=$_.Split("=",2); Set-Item "env:$n" $v }

# API + worker Postgres connection string. Use the pilot database you create
# after Bicep deployment (recommended database name: ailibrarian).
ConnectionStrings__Postgres=Host=<postgres-fqdn>;Port=5432;Database=ailibrarian;Username=ailibrarian;Password=<password>;Ssl Mode=Require;Trust Server Certificate=true
IngestWorker__Database__ConnectionString=Host=<postgres-fqdn>;Port=5432;Database=ailibrarian;Username=ailibrarian;Password=<password>;Ssl Mode=Require;Trust Server Certificate=true

# API blob uploads and worker blob reads.
BlobStorage__ConnectionString=<storage-connection-string>
BlobStorage__ContainerName=sources
IngestWorker__Blob__ConnectionString=<storage-connection-string>
IngestWorker__Blob__UseManagedIdentity=false

# API enqueue and worker dequeue.
IngestQueue__ConnectionString=<service-bus-connection-string>
IngestQueue__QueueName=ingest-jobs
IngestWorker__ServiceBus__ConnectionString=<service-bus-connection-string>
IngestWorker__ServiceBus__IngestQueueName=ingest-jobs

# Local pilot upload escape hatch (Development only). These IDs are examples;
# keep them consistent with the seed SQL in deploy/runbooks/pilot-minimal-azure.md.
Portal__DefaultDepartmentId=11111111-1111-1111-1111-111111111111
Portal__DefaultClassification=Internal
Portal__DefaultContributorId=22222222-2222-2222-2222-222222222222
Portal__DevelopmentRlsOverrideEnabled=true
AILIB_PILOT_CONTRIBUTOR_ID=22222222-2222-2222-2222-222222222222

# Portal -> API.
Api__BaseUrl=http://localhost:5071/

# Optional Azure OpenAI. Leave disabled for upload/enqueue-only smoke.
LlmGateway__Providers__azure-openai__Enabled=false
LlmGateway__Providers__azure-openai__Endpoint=
LlmGateway__Providers__azure-openai__ApiKey=
LlmGateway__Providers__azure-openai__ChatDeployment=
LlmGateway__Providers__azure-openai__EmbeddingDeployment=
Search__EmbeddingDeployment=
IngestWorker__Processing__RunContentPipeline=true
IngestWorker__Processing__GenerateEmbeddings=false
IngestWorker__Embeddings__ModelDeploymentName=
