{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.43.8.12551",
      "templateHash": "6558559154361284162"
    }
  },
  "parameters": {
    "namePrefix": {
      "type": "string",
      "defaultValue": "ailib",
      "minLength": 2,
      "maxLength": 10,
      "metadata": {
        "description": "Short name prefix used inside resource names (Storage, Postgres, etc.)."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for every resource in this deployment."
      }
    },
    "environment": {
      "type": "string",
      "defaultValue": "pilot",
      "metadata": {
        "description": "Environment label applied as a tag (pilot / dev / stage / prod)."
      }
    },
    "postgresAdminLogin": {
      "type": "string",
      "defaultValue": "ailibrarian",
      "metadata": {
        "description": "PostgreSQL flexible server administrator login."
      }
    },
    "postgresAdminPassword": {
      "type": "securestring",
      "metadata": {
        "description": "PostgreSQL administrator password — supply via CLI or CI secret; never commit."
      }
    },
    "postgresSkuName": {
      "type": "string",
      "defaultValue": "Standard_B1ms",
      "metadata": {
        "description": "Burstable SKU for PostgreSQL Flexible Server."
      }
    },
    "postgresSkuTier": {
      "type": "string",
      "defaultValue": "Burstable",
      "metadata": {
        "description": "SKU tier for PostgreSQL Flexible Server."
      }
    }
  },
  "variables": {
    "nameSuffix": "[uniqueString(resourceGroup().id, deployment().name)]",
    "commonTags": {
      "audit-scope": "ai-librarian",
      "environment": "[parameters('environment')]",
      "workload": "ai-librarian",
      "deployment": "pilot-data-plane"
    },
    "postgresServerName": "[take(toLower(format('psql-{0}-{1}', parameters('namePrefix'), variables('nameSuffix'))), 63)]"
  },
  "resources": [
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "storage",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "parameters": {
          "location": {
            "value": "[parameters('location')]"
          },
          "nameSuffix": {
            "value": "[variables('nameSuffix')]"
          },
          "tags": {
            "value": "[variables('commonTags')]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.43.8.12551",
              "templateHash": "6956758814754494652"
            }
          },
          "parameters": {
            "location": {
              "type": "string",
              "metadata": {
                "description": "Azure region for the storage account."
              }
            },
            "nameSuffix": {
              "type": "string",
              "metadata": {
                "description": "Stable suffix derived from resourceGroup().id (used inside the account name)."
              }
            },
            "tags": {
              "type": "object",
              "metadata": {
                "description": "Resource tags."
              }
            }
          },
          "variables": {
            "storageAccountName": "[take(toLower(format('stailib{0}', parameters('nameSuffix'))), 24)]"
          },
          "resources": [
            {
              "type": "Microsoft.Storage/storageAccounts",
              "apiVersion": "2023-04-01",
              "name": "[variables('storageAccountName')]",
              "location": "[parameters('location')]",
              "tags": "[parameters('tags')]",
              "sku": {
                "name": "Standard_LRS"
              },
              "kind": "StorageV2",
              "properties": {
                "minimumTlsVersion": "TLS1_2",
                "allowBlobPublicAccess": false,
                "supportsHttpsTrafficOnly": true,
                "allowSharedKeyAccess": true,
                "encryption": {
                  "services": {
                    "blob": {
                      "enabled": true
                    },
                    "file": {
                      "enabled": true
                    }
                  },
                  "keySource": "Microsoft.Storage"
                },
                "networkAcls": {
                  "defaultAction": "Allow"
                }
              }
            },
            {
              "type": "Microsoft.Storage/storageAccounts/blobServices",
              "apiVersion": "2023-04-01",
              "name": "[format('{0}/{1}', variables('storageAccountName'), 'default')]",
              "properties": {
                "deleteRetentionPolicy": {
                  "enabled": true,
                  "days": 7
                },
                "containerDeleteRetentionPolicy": {
                  "enabled": true,
                  "days": 7
                },
                "isVersioningEnabled": true,
                "changeFeed": {
                  "enabled": false
                }
              },
              "dependsOn": [
                "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName'))]"
              ]
            },
            {
              "type": "Microsoft.Storage/storageAccounts/blobServices/containers",
              "apiVersion": "2023-04-01",
              "name": "[format('{0}/{1}/{2}', variables('storageAccountName'), 'default', 'sources')]",
              "properties": {
                "publicAccess": "None",
                "immutableStorageWithVersioning": {
                  "enabled": true
                }
              },
              "dependsOn": [
                "[resourceId('Microsoft.Storage/storageAccounts/blobServices', variables('storageAccountName'), 'default')]"
              ]
            },
            {
              "type": "Microsoft.Storage/storageAccounts/blobServices/containers/immutabilityPolicies",
              "apiVersion": "2023-04-01",
              "name": "[format('{0}/{1}/{2}/{3}', variables('storageAccountName'), 'default', 'sources', 'default')]",
              "properties": {
                "immutabilityPeriodSinceCreationInDays": 1,
                "allowProtectedAppendWrites": false
              },
              "dependsOn": [
                "[resourceId('Microsoft.Storage/storageAccounts/blobServices/containers', variables('storageAccountName'), 'default', 'sources')]"
              ]
            }
          ],
          "outputs": {
            "storageAccountId": {
              "type": "string",
              "metadata": {
                "description": "Storage account resource id."
              },
              "value": "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName'))]"
            },
            "blobEndpoint": {
              "type": "string",
              "metadata": {
                "description": "Blob endpoint URL (https://<account>.blob.core.windows.net/)."
              },
              "value": "[reference(resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName')), '2023-04-01').primaryEndpoints.blob]"
            },
            "storageAccountName": {
              "type": "string",
              "metadata": {
                "description": "Storage account name (for connection strings / MI RBAC)."
              },
              "value": "[variables('storageAccountName')]"
            }
          }
        }
      }
    },
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "servicebus",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "parameters": {
          "location": {
            "value": "[parameters('location')]"
          },
          "nameSuffix": {
            "value": "[variables('nameSuffix')]"
          },
          "tags": {
            "value": "[variables('commonTags')]"
          },
          "skuName": {
            "value": "Basic"
          },
          "skuTier": {
            "value": "Basic"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.43.8.12551",
              "templateHash": "10701128504684738657"
            }
          },
          "parameters": {
            "location": {
              "type": "string",
              "metadata": {
                "description": "Azure region for the namespace."
              }
            },
            "nameSuffix": {
              "type": "string",
              "metadata": {
                "description": "Stable suffix derived from resourceGroup().id."
              }
            },
            "tags": {
              "type": "object",
              "metadata": {
                "description": "Resource tags."
              }
            },
            "skuName": {
              "type": "string",
              "defaultValue": "Standard",
              "allowedValues": [
                "Basic",
                "Standard",
                "Premium"
              ],
              "metadata": {
                "description": "Service Bus SKU name. Basic is lowest cost and supports queues needed for ingest."
              }
            },
            "skuTier": {
              "type": "string",
              "defaultValue": "Standard",
              "allowedValues": [
                "Basic",
                "Standard",
                "Premium"
              ],
              "metadata": {
                "description": "Service Bus SKU tier (must match skuName: Basic/Basic, Standard/Standard, Premium/Premium)."
              }
            },
            "ingestQueueName": {
              "type": "string",
              "defaultValue": "ingest-jobs",
              "metadata": {
                "description": "Ingest queue consumed by AiLibrarian.IngestWorker and written by AiLibrarian.Api."
              }
            }
          },
          "variables": {
            "namespaceName": "[take(format('sb-ai-{0}', parameters('nameSuffix')), 50)]"
          },
          "resources": [
            {
              "type": "Microsoft.ServiceBus/namespaces",
              "apiVersion": "2022-10-01-preview",
              "name": "[variables('namespaceName')]",
              "location": "[parameters('location')]",
              "tags": "[parameters('tags')]",
              "sku": {
                "name": "[parameters('skuName')]",
                "tier": "[parameters('skuTier')]"
              },
              "properties": {
                "minimumTlsVersion": "1.2",
                "publicNetworkAccess": "Enabled",
                "disableLocalAuth": false,
                "zoneRedundant": false
              }
            },
            {
              "type": "Microsoft.ServiceBus/namespaces/queues",
              "apiVersion": "2022-10-01-preview",
              "name": "[format('{0}/{1}', variables('namespaceName'), parameters('ingestQueueName'))]",
              "properties": {
                "maxSizeInMegabytes": 1024,
                "defaultMessageTimeToLive": "P14D",
                "lockDuration": "PT1M",
                "maxDeliveryCount": 10
              },
              "dependsOn": [
                "[resourceId('Microsoft.ServiceBus/namespaces', variables('namespaceName'))]"
              ]
            }
          ],
          "outputs": {
            "namespaceId": {
              "type": "string",
              "metadata": {
                "description": "Service Bus namespace resource id."
              },
              "value": "[resourceId('Microsoft.ServiceBus/namespaces', variables('namespaceName'))]"
            },
            "hostname": {
              "type": "string",
              "metadata": {
                "description": "Service Bus hostname (for connection strings / RBAC)."
              },
              "value": "[format('{0}.servicebus.windows.net', variables('namespaceName'))]"
            },
            "namespaceName": {
              "type": "string",
              "metadata": {
                "description": "Service Bus namespace name."
              },
              "value": "[variables('namespaceName')]"
            },
            "ingestQueueName": {
              "type": "string",
              "metadata": {
                "description": "Ingest queue name."
              },
              "value": "[parameters('ingestQueueName')]"
            }
          }
        }
      }
    },
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "postgres",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "parameters": {
          "location": {
            "value": "[parameters('location')]"
          },
          "serverName": {
            "value": "[variables('postgresServerName')]"
          },
          "administratorLogin": {
            "value": "[parameters('postgresAdminLogin')]"
          },
          "administratorLoginPassword": {
            "value": "[parameters('postgresAdminPassword')]"
          },
          "tags": {
            "value": "[variables('commonTags')]"
          },
          "skuName": {
            "value": "[parameters('postgresSkuName')]"
          },
          "skuTier": {
            "value": "[parameters('postgresSkuTier')]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.43.8.12551",
              "templateHash": "3900375276815980201"
            }
          },
          "parameters": {
            "location": {
              "type": "string",
              "metadata": {
                "description": "Azure region for the server."
              }
            },
            "serverName": {
              "type": "string",
              "metadata": {
                "description": "Globally unique server name (lowercase letters, numbers, hyphens; 3-63)."
              }
            },
            "administratorLogin": {
              "type": "string",
              "metadata": {
                "description": "Administrator login (not azure_superuser)."
              }
            },
            "administratorLoginPassword": {
              "type": "securestring",
              "metadata": {
                "description": "Administrator password (pass via CLI or secure parameter file; never commit)."
              }
            },
            "tags": {
              "type": "object",
              "metadata": {
                "description": "Resource tags."
              }
            },
            "postgresVersion": {
              "type": "string",
              "defaultValue": "16",
              "metadata": {
                "description": "PostgreSQL major version."
              }
            },
            "skuName": {
              "type": "string",
              "defaultValue": "Standard_B1ms",
              "metadata": {
                "description": "Burstable SKU name for cost-conscious dev; scale up for production."
              }
            },
            "skuTier": {
              "type": "string",
              "defaultValue": "Burstable",
              "metadata": {
                "description": "Burstable tier name."
              }
            }
          },
          "resources": [
            {
              "type": "Microsoft.DBforPostgreSQL/flexibleServers",
              "apiVersion": "2024-08-01",
              "name": "[parameters('serverName')]",
              "location": "[parameters('location')]",
              "tags": "[parameters('tags')]",
              "sku": {
                "name": "[parameters('skuName')]",
                "tier": "[parameters('skuTier')]"
              },
              "properties": {
                "version": "[parameters('postgresVersion')]",
                "administratorLogin": "[parameters('administratorLogin')]",
                "administratorLoginPassword": "[parameters('administratorLoginPassword')]",
                "storage": {
                  "storageSizeGB": 32
                },
                "network": {
                  "publicNetworkAccess": "Enabled"
                },
                "authConfig": {
                  "activeDirectoryAuth": "Disabled",
                  "passwordAuth": "Enabled"
                },
                "backup": {
                  "backupRetentionDays": 7,
                  "geoRedundantBackup": "Disabled"
                },
                "highAvailability": {
                  "mode": "Disabled"
                }
              }
            },
            {
              "type": "Microsoft.DBforPostgreSQL/flexibleServers/configurations",
              "apiVersion": "2024-08-01",
              "name": "[format('{0}/{1}', parameters('serverName'), 'azure.extensions')]",
              "properties": {
                "value": "VECTOR,PG_TRGM,CITEXT,PGCRYPTO",
                "source": "user-override"
              },
              "dependsOn": [
                "[resourceId('Microsoft.DBforPostgreSQL/flexibleServers', parameters('serverName'))]"
              ]
            },
            {
              "type": "Microsoft.DBforPostgreSQL/flexibleServers/firewallRules",
              "apiVersion": "2024-08-01",
              "name": "[format('{0}/{1}', parameters('serverName'), 'AllowAllAzureServicesAndResourcesWithinAzureIps_2024-04-01')]",
              "properties": {
                "startIpAddress": "0.0.0.0",
                "endIpAddress": "0.0.0.0"
              },
              "dependsOn": [
                "[resourceId('Microsoft.DBforPostgreSQL/flexibleServers', parameters('serverName'))]"
              ]
            }
          ],
          "outputs": {
            "serverId": {
              "type": "string",
              "metadata": {
                "description": "Flexible server resource id."
              },
              "value": "[resourceId('Microsoft.DBforPostgreSQL/flexibleServers', parameters('serverName'))]"
            },
            "fqdn": {
              "type": "string",
              "metadata": {
                "description": "Fully qualified domain name of the PostgreSQL server."
              },
              "value": "[reference(resourceId('Microsoft.DBforPostgreSQL/flexibleServers', parameters('serverName')), '2024-08-01').fullyQualifiedDomainName]"
            },
            "administratorLoginOut": {
              "type": "string",
              "metadata": {
                "description": "Echo of the administrator login passed at deploy time."
              },
              "value": "[parameters('administratorLogin')]"
            }
          }
        }
      }
    }
  ],
  "outputs": {
    "nameSuffix": {
      "type": "string",
      "value": "[variables('nameSuffix')]"
    },
    "storageAccountId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'storage'), '2025-04-01').outputs.storageAccountId.value]"
    },
    "storageAccountName": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'storage'), '2025-04-01').outputs.storageAccountName.value]"
    },
    "blobEndpoint": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'storage'), '2025-04-01').outputs.blobEndpoint.value]"
    },
    "serviceBusNamespaceId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'servicebus'), '2025-04-01').outputs.namespaceId.value]"
    },
    "serviceBusNamespaceName": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'servicebus'), '2025-04-01').outputs.namespaceName.value]"
    },
    "serviceBusHostname": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'servicebus'), '2025-04-01').outputs.hostname.value]"
    },
    "serviceBusIngestQueueName": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'servicebus'), '2025-04-01').outputs.ingestQueueName.value]"
    },
    "postgresServerId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'postgres'), '2025-04-01').outputs.serverId.value]"
    },
    "postgresFqdn": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'postgres'), '2025-04-01').outputs.fqdn.value]"
    },
    "postgresServerName": {
      "type": "string",
      "value": "[variables('postgresServerName')]"
    },
    "postgresAdministratorLogin": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'postgres'), '2025-04-01').outputs.administratorLoginOut.value]"
    }
  }
}